{
  "name": "webforms-ui",
  "version": "7.1.3",
  "private": false,
  "scripts": {
    "start": "export VITE_APP_VERSION=$(git describe --tags) && vite",
    "build": "npm run lint:todos; export VITE_APP_VERSION=$(git describe --tags) && vite build",
    "build:ov": "npm run build -- --mode=ov",
    "build:prod": "npm run build -- --mode=prod",
    "build:pre": "npm run build -- --mode=pre",
    "build:vercel": "npm run build -- --mode=vercel",
    "test": "TZ=Europe/Madrid vitest",
    "test:coverage": "TZ=Europe/Madrid vitest run --coverage",
    "cypress": "TZ=Europe/Madrid cypress open",
    "cypress:smoke": "TZ=Europe/Madrid cypress run --env configFile=production",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:todos": "./scripts/todos.sh src/",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "i18n-extract": "./node_modules/.bin/i18next src/**/*.js* -o src/i18n/locale-xx.json -s",
    "i18n-lint": "./scripts/lint-i18n.sh",
    "preview": "vite preview"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@googlemaps/js-api-loader": "^1.16.6",
    "@mui/icons-material": "^6.5.0",
    "@mui/material": "^6.5.0",
    "@mui/x-date-pickers": "^7.0.0",
    "@somenergia/somenergia-ui": "^1.0.1",
    "axios": "^1.13.5",
    "dayjs": "^1.11.19",
    "formik": "^2.4.9",
    "i18next": "^23.11.2",
    "ibantools": "^4.5.1",
    "libphonenumber-js": "^1.12.36",
    "plausible-tracker": "^0.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-facebook-pixel": "^1.0.4",
    "react-hotkeys": "^2.0.0",
    "react-i18next": "^14.0.0",
    "react-router-dom": "^6.2.2",
    "stdnum": "^1.11.7",
    "yup": "^0.32.11"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "trustedDependencies": [
    "@somenergia-ui/somenergia-ui",
    "@swc/core",
    "cypress",
    "esbuild"
  ],
  "devDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@somenergia/frontend-config": "github:Som-Energia/frontend-config#v1.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.6.0",
    "@vitest/coverage-v8": "^4.0.18",
    "cypress": "^12.17.4",
    "cypress-file-upload": "^5.0.8",
    "eslint": "^9.39.4",
    "eslint-plugin-cypress": "^3.6.0",
    "i18next-parser": "^9.3.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.8.3",
    "vite": "^5.2.11",
    "vite-plugin-environment": "^1.1.3",
    "vite-plugin-eslint2": "^5.1.0",
    "vite-plugin-svgr": "^4.5.0",
    "vitest": "^4.0.18"
  }
}
